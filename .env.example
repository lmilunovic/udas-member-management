# Database (PostgreSQL)
POSTGRES_DB=udas_member_management
POSTGRES_USER=udas
POSTGRES_PASSWORD=

# Backend
SPRING_PROFILES_ACTIVE=dev
DB_HOST=postgres
DB_PORT=5432
DB_NAME=udas_member_management
DB_USERNAME=udas
DB_PASSWORD=

# Admin user — this email receives the ADMIN role on first Google login
ADMIN_EMAIL=

# Frontend — leave empty for dev/docker (Vite proxy handles routing); set full API base URL in production
VITE_BACKEND_URL=

# Google OAuth2 — create credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
